{
  "expo": {
    "name": "react-native-mre",
    "slug": "react-native-mre",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "react-native-mre",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "org.artiekra.reactnativemre"
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "transparent"
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "backgroundColor": "transparent"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
